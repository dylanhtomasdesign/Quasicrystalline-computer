# =============================================================================
# Senemosìa Punto Zero v2.0 - Development Environment
# =============================================================================
# 
# Lightweight development container with volume mounts for:
# - Source code (mounted from host)
# - Heavy data (mounted from host or external volume)
# - Model checkpoints (persistent volume)
#
# Usage:
#   docker build -f docker/Dockerfile.dev -t senemosia:dev .
#   docker run --gpus all -v $(pwd):/workspace -v data_volume:/data senemosia:dev
#

FROM nvidia/cuda:11.8-cudnn8-runtime-ubuntu22.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# ============================================================================
# BASE DEPENDENCIES
# ============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core tools
    git \
    curl \
    wget \
    vim \
    htop \
    build-essential \
    # Python
    python3.11 \
    python3.11-dev \
    python3-pip \
    python3.11-venv \
    # Scientific computing
    libopenblas-dev \
    liblapack-dev \
    libgomp1 \
    # Version control
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.11 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

# ============================================================================
# CORE PYTHON PACKAGES (Lightweight - loaded at runtime from requirements.txt)
# ============================================================================
# Note: Heavy ML packages (torch, tensorflow) are NOT installed here
# They are mounted via volume or installed separately for specific runs

WORKDIR /workspace

# Create virtual environment (slim)
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install only core packages first (fast build)
COPY requirements-core.txt /tmp/
RUN pip install --no-cache-dir -r /tmp/requirements-core.txt && \
    rm /tmp/requirements-core.txt

# ============================================================================
# OPTIONAL: HEAVY ML PACKAGES (install on-demand or via volume)
# ============================================================================
# Uncomment for GPU-accelerated ML:
# RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu118

# ============================================================================
# ENVIRONMENT SETUP
# ============================================================================
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/workspace:$PYTHONPATH
ENV OMP_NUM_THREADS=4
ENV MKL_NUM_THREADS=4

# ============================================================================
# DATA VOLUMES (mounted at runtime)
# ============================================================================
# These directories are prepared but EMPTY - they receive data from host/volume
VOLUME ["/data", "/models", "/outputs"]

# ============================================================================
# ENTRY POINT
# ============================================================================
# Lightweight startup - just drop to shell
CMD ["/bin/bash"]
